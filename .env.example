# ============================
# Spring 공통
# ============================
spring.profiles.active=local,api

# docker compose 프로젝트 이름
COMPOSE_PROJECT_NAME=tradinggate_docker


# ============================
# PostgreSQL – Trading DB
# ============================
TRADING_DB_HOST=localhost
TRADING_DB_PORT=5432
TRADING_DB_USER=trading_user
TRADING_DB_PASSWORD=trading_pass
TRADING_DB_NAME=trading_db

# ============================
# PostgreSQL – Ledger DB
# ============================
LEDGER_DB_HOST=localhost
LEDGER_DB_PORT=5433
LEDGER_DB_USER=ledger_user
LEDGER_DB_PASSWORD=ledger_pass
LEDGER_DB_NAME=ledger_db

# ============================
# Redis
# ============================
# 로컬에서 스프링 실행 → localhost
# 나중에 스프링도 도커에서 돌리면: REDIS_HOST=redis 로 바꾸면 됨
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis password가 필요하면 설정
REDIS_PASSWORD=

# ============================
# Kafka / Zookeeper
# ============================
# docker-compose: zookeeper 포트 매핑에 사용됨
ZOOKEEPER_PORT=2181

# 로컬에서 스프링 실행:
#   bootstrap-servers = localhost:9092
# 도커에서 스프링 실행:
#   bootstrap-servers = kafka:9092
KAFKA_BROKER_HOST=localhost
KAFKA_BROKER_PORT=9092

# Kafka cluster tuning
KAFKA_NUM_PARTITIONS=12

# ============================
# Spring 서버 포트 (프로필별)
# ============================
# local 프로필에서 사용
APP_PORT=8080

# api 프로필에서 사용 (application.yml: server.port: ${API_PORT:8080})
API_PORT=8080

# projection 프로필에서 사용 (application.yml: ${PROJECTION_PORT:8090})
PROJECTION_PORT=8090


# ============================
# Kafka client 메타 정보 (선택)
# ============================
KAFKA_CLIENT_ID=trading-gate
KAFKA_GROUP_API=api-group
KAFKA_GROUP_RISK=risk-group


# ============================
# Auth (나중 확장용)
# ============================
AUTH_SECRET_KEY=changeme